# StreamVault Environment Variables
# Copy this to .env and fill in your values

STREAMVAULT_AUTH_SECRET=change-me-to-a-random-secret
STREAMVAULT_PUBLIC_BASE_URL=http://localhost:8080

# Optional — these can also be set via the dashboard UI
STREAMVAULT_GH_TOKEN=
STREAMVAULT_GH_REPO=
STREAMVAULT_DISCORD_BOT_TOKEN=
STREAMVAULT_DISCORD_CHANNEL_ID=
STREAMVAULT_TELEGRAM_BOT_TOKEN=
STREAMVAULT_TELEGRAM_CHANNEL_ID=
STREAMVAULT_TORRENTIO_BASE_URL=

RUST_LOG=info
